{
  "name": "{{authorShort}}/{{slug}}",
  "version": "0.1.0",
  "license": "GPL-2.0-or-later",
  "autoload": {
    "psr-4": {
      "{{phpNamespace}}\\": "inc/app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "{{phpNamespace}}\\Tests\\": "tests/php/"
    }
  },
  "repositories": [
    {
      "type": "package",
      "package": {
        "name": "wordpress/wordpress-tests-phpunit",
        "version": "{{wordpressVersion}}",
        "source": {
          "url": "https://develop.svn.wordpress.org/tags/{{wordpressVersion}}/tests/",
          "type": "svn",
          "reference": "phpunit/"
        }
      }
    }
  ],
  "require": {
    "php": ">={{phpVersion}}"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6.34",
    "yoast/phpunit-polyfills": "^4.0",
    "vlucas/phpdotenv": "^5.6",
    "wordpress/wordpress-tests-phpunit": "{{wordpressVersion}}"
  },
  "scripts": {
    "test": "./dev-tools/docker/run-tests.sh"
  }
}
